DOMAIN=example.com
ACME_EMAIL=admin@example.com

SECRET_KEY=change_this_to_a_long_random_secret
POSTGRES_DB=fb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_database_password

# Optional: comma-separated extra hosts accepted by Django.
PRODUCTION_HOSTS=backend

# Optional: override when frontend and API are split across domains.
REACT_APP_API_URL=/api
CSRF_TRUSTED_ORIGINS=https://example.com

# Leave enabled for normal production startup.
RUN_MIGRATIONS=1
RUN_COLLECTSTATIC=1
